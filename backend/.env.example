DATABASE_URL="postgresql://postgres:postgres@localhost:5432/education_crm?schema=public"
JWT_SECRET="change_me_to_a_long_secure_secret"
JWT_EXPIRES_IN="7d"
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# Seed credentials
# Required: SEED_SUPERADMIN_PASSWORD
# Optional: default admin/counselor are only created when SEED_DEFAULT_PASSWORD is set
SEED_SUPERADMIN_EMAIL="superadmin@crm.local"
SEED_SUPERADMIN_NAME="Super Admin"
SEED_SUPERADMIN_PASSWORD="replace_with_strong_superadmin_password"
SEED_DEFAULT_ADMIN_EMAIL="admin@crm.local"
SEED_DEFAULT_COUNSELOR_EMAIL="counselor@crm.local"
SEED_DEFAULT_PASSWORD="replace_with_strong_default_password"
