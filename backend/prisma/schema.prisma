generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  ADMIN
  COUNSELOR
}

enum LeadStatus {
  LEAD
  CONTACTED
  NOT_INTERESTED
  INTERESTED
  QUALIFIED
  APPLIED
  ENROLLED
}

enum ActivityType {
  CALL
  WHATSAPP
  EMAIL
  NOTE
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum Priority {
  COLD
  WARM
  HOT
}

enum BackupStatus {
  CREATED
  FAILED
  RESTORED
  RESTORE_FAILED
  DELETED
}

model Tenant {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String   @unique
  description   String?
  courseOptions Json     @default(dbgenerated("'[]'::jsonb")) @map("course_options") @db.JsonB
  maxUsers      Int      @default(10) @map("max_users")
  isActive      Boolean  @default(true) @map("is_active")
  users         User[]
  leads         Lead[]
  activities    Activity[]
  whatsappMessages WhatsAppMessage[]
  smsMessages   SMSMessage[]
  reports       Report[]
  integrationApiKeys IntegrationApiKey[]
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

model User {
  id              Int      @id @default(autoincrement())
  tenantId        Int      @map("tenant_id")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  email           String   @map("email")
  password        String
  role            Role     @default(COUNSELOR)
  leadsAssigned   Lead[]   @relation("LeadAssignedTo")
  assignmentBatches LeadAssignmentBatch[] @relation("LeadAssignmentBatchTo")
  whatsappMessages WhatsAppMessage[]
  smsMessages     SMSMessage[]
  reports         Report[]
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Lead {
  id               Int         @id @default(autoincrement())
  tenantId         Int         @map("tenant_id")
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  phone            String
  email            String?
  address          String?
  region           String?
  city             String?
  locality         String?
  pincode          String?
  studentCasteCategory String?  @map("student_caste_category")
  parentContact    String?     @map("parent_contact")
  course           String?
  source           String?
  campaign         String?
  medium           String?
  partnerSource    String?     @map("partner_source")
  remarks          String?     @db.Text
  status           LeadStatus  @default(LEAD)
  priority         Priority    @default(COLD)
  nextFollowUp     DateTime?   @map("next_follow_up")
  assignedTo       Int?        @map("assigned_to")
  assignedCounselor User?      @relation("LeadAssignedTo", fields: [assignedTo], references: [id])
  activities       Activity[]
  whatsappMessages WhatsAppMessage[]
  smsMessages      SMSMessage[]
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([tenantId, nextFollowUp])
  @@index([tenantId, city])
  @@index([tenantId, locality])
  @@index([tenantId, region])
  @@index([tenantId, pincode])
  @@index([assignedTo])
  @@map("leads")
}

model LeadAssignmentLog {
  id            String   @id @default(cuid())
  leadId        Int      @map("lead_id")
  tenantId      Int      @map("tenant_id")
  oldAssignedTo Int?     @map("old_assigned_to")
  newAssignedTo Int?     @map("new_assigned_to")
  assignedBy    Int?     @map("assigned_by")
  actionType    String   @map("action_type")
  sourceModule  String   @map("source_module")
  batchId       String?  @map("batch_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([leadId])
  @@index([oldAssignedTo])
  @@index([newAssignedTo])
  @@index([assignedBy])
  @@index([batchId])
  @@index([createdAt])
  @@map("lead_assignment_logs")
}

model LeadAssignmentBatch {
  batchId    String   @id @default(cuid()) @map("batch_id")
  tenantId   Int      @map("tenant_id")
  assignedBy Int?     @map("assigned_by")
  assignedTo Int?     @map("assigned_to")
  assignedToUser User? @relation("LeadAssignmentBatchTo", fields: [assignedTo], references: [id])
  leadCount  Int      @map("lead_count")
  pincode    String?
  source     String?
  startRange Int      @map("start_range")
  endRange   Int      @map("end_range")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([assignedBy])
  @@index([assignedTo])
  @@index([createdAt])
  @@map("lead_assignment_batches")
}

model BackupRecord {
  id               Int          @id @default(autoincrement())
  filename         String
  filePath         String       @map("file_path")
  fileSize         BigInt       @default(0) @map("file_size")
  status           BackupStatus
  createdByUserId  Int?         @map("created_by_user_id")
  restoredByUserId Int?         @map("restored_by_user_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  restoredAt       DateTime?    @map("restored_at")
  notes            String?
  checksum         String?

  @@index([status])
  @@index([createdAt])
  @@index([createdByUserId])
  @@index([restoredByUserId])
  @@map("backup_records")
}

model IntegrationApiKey {
  id               Int      @id @default(autoincrement())
  tenantId         Int      @map("tenant_id")
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partner          String
  name             String?
  apiKeyHash       String   @map("api_key_hash")
  apiKeyPrefix     String   @map("api_key_prefix")
  isActive         Boolean  @default(true) @map("is_active")
  rateLimitPerMin  Int      @default(60) @map("rate_limit_per_min")
  lastUsedAt       DateTime? @map("last_used_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([partner, apiKeyHash])
  @@index([tenantId, partner, isActive])
  @@map("integration_api_keys")
}

model Activity {
  id           Int          @id @default(autoincrement())
  tenantId     Int          @map("tenant_id")
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId       Int          @map("lead_id")
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type         ActivityType
  notes        String
  createdAt    DateTime     @default(now()) @map("created_at")
  nextFollowUp DateTime     @map("next_follow_up")

  @@index([tenantId])
  @@index([leadId])
  @@map("activities")
}

model WhatsAppMessage {
  id              Int             @id @default(autoincrement())
  tenantId        Int             @map("tenant_id")
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId          Int             @map("lead_id")
  lead            Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sentBy          Int             @map("sent_by")
  user            User            @relation(fields: [sentBy], references: [id])
  message         String
  status          MessageStatus   @default(PENDING)
  direction       MessageDirection
  phoneNumber     String          @map("phone_number")
  messageId       String?         @map("message_id")
  mediaUrl        String?         @map("media_url")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([leadId])
  @@index([sentBy])
  @@map("whatsapp_messages")
}

model SMSMessage {
  id              Int             @id @default(autoincrement())
  tenantId        Int             @map("tenant_id")
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId          Int             @map("lead_id")
  lead            Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sentBy          Int             @map("sent_by")
  user            User            @relation(fields: [sentBy], references: [id])
  message         String
  status          MessageStatus   @default(PENDING)
  direction       MessageDirection
  phoneNumber     String          @map("phone_number")
  messageId       String?         @map("message_id")
  provider        String          @default("twilio")
  cost            Float?          @default(0)
  errorCode       String?         @map("error_code")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([leadId])
  @@index([sentBy])
  @@map("sms_messages")
}

model Report {
  id              Int             @id @default(autoincrement())
  tenantId        Int             @map("tenant_id")
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  reportType      String          @map("report_type")
  generatedBy     Int             @map("generated_by")
  user            User            @relation(fields: [generatedBy], references: [id])
  data            Json
  filters         Json?
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([generatedBy])
  @@map("reports")
}

model SecurityEvent {
  id              String          @id @default(cuid())
  tenantId        Int             @map("tenant_id")
  userId          Int?            @map("user_id")
  action          String          // LOGIN, LOGOUT, DATA_ACCESS, PERMISSION_DENIED, DATA_MODIFICATION, etc.
  resource        String          // leads, activities, bulk, messaging, etc.
  resourceId      Int?            @map("resource_id")
  status          String          // success, blocked, error
  details         Json?           // Additional context
  ipAddress       String?         @map("ip_address")
  userAgent       String?         @map("user_agent")
  timestamp       DateTime        @default(now())
  
  @@index([tenantId])
  @@index([userId])
  @@index([timestamp])
  @@index([status])
  @@map("security_events")
}

model ApiRequestLog {
  id            Int      @id @default(autoincrement())
  tenantId      Int?     @map("tenant_id")
  userId        Int?     @map("user_id")
  method        String
  path          String
  statusCode    Int      @map("status_code")
  durationMs    Int      @map("duration_ms")
  requestSize   Int?     @map("request_size")
  responseSize  Int?     @map("response_size")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([userId])
  @@index([statusCode])
  @@index([createdAt])
  @@index([path])
  @@map("api_request_logs")
}
