{
  "name": "education-crm-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "promote:superadmin": "tsx scripts/promote-superadmin.ts",
    "reset:user-password": "tsx scripts/reset-user-password.ts",
    "backfill:lead-location": "tsx scripts/backfill-lead-location.ts",
    "reconcile:leads-csv": "tsx scripts/reconcile-leads-from-csv.ts",
    "integration:key:create": "tsx scripts/create-integration-api-key.ts",
    "seed:engineering": "tsx scripts/seed-engineering-leads.ts --count 500",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js src/__tests__/unit",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js src/__tests__/integration",
    "test:e2e": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js src/__tests__/e2e",
    "test:ci": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --ci --coverage --detectOpenHandles"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@prisma/engines": "^7.6.0",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.9",
    "twilio": "^5.13.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.11",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^2.0.12",
    "jest": "^29.7.0",
    "prisma": "^6.5.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
