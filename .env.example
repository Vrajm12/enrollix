# Database
DATABASE_URL=postgresql://user:password@localhost:5432/education_crm

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-8-characters
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Optional: WhatsApp Business API
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_TOKEN=
META_VERIFY_TOKEN=

# Optional: Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: SMTP Email (for bulk email)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Local safety rails for bulk email testing
EMAIL_BULK_MAX_RECIPIENTS=200
EMAIL_BULK_DELAY_MS=250
